# Required
DATABASE_URL=postgres://signup:signup@localhost:5433/signup
AUTH_SECRET=change-me-to-a-32-byte-random-string-XXXXXXXXX
AUTH_URL=http://localhost:3000

# How long magic-link sign-in emails stay valid, in minutes.
# Default 60. Min 1, max 10080 (1 week). Shorter = more secure; longer = more
# forgiving if users don't check their inbox immediately.
AUTH_MAGIC_LINK_MAX_AGE_MINUTES=60

# Email transport: console | smtp | resend
EMAIL_TRANSPORT=console
EMAIL_FROM="OpenSignup <hello@signup.local>"

# If EMAIL_TRANSPORT=resend
RESEND_API_KEY=

# If EMAIL_TRANSPORT=smtp
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_SECURE=false

# Optional observability (unset = disabled)
SENTRY_DSN=
POSTHOG_KEY=
POSTHOG_HOST=https://app.posthog.com

# Optional Google OAuth sign-in for organizers. Off unless BOTH are set.
# Create an OAuth client at https://console.cloud.google.com/apis/credentials
# and register the redirect URI {AUTH_URL}/api/auth/callback/google
# (e.g. http://localhost:3000/api/auth/callback/google for local dev).
# GitHub and Apple sign-in are planned for a later release.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Public base URL (used for building participant/share links, and as the
# canonical origin for SEO: sitemap.xml, robots.txt, and Open Graph image
# URLs). Inlined at build time — see Dockerfile / fly.toml build-arg wiring.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Magic Compose (AI-drafted signups). Optional. Any OpenAI-compatible Chat Completions endpoint.
# OpenRouter: LLM_BASE_URL=https://openrouter.ai/api/v1 + LLM_MODEL=openai/gpt-4o-mini
# OpenAI:     LLM_BASE_URL=https://api.openai.com/v1    + LLM_MODEL=gpt-4o-mini
# Ollama:     LLM_BASE_URL=http://localhost:11434/v1    + LLM_MODEL=llama3.1:8b  (LLM_API_KEY optional)
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=
# Request timeout in ms (default 180000 = 3 min). Structured outputs on
# large drafts can take >60s on some providers; bump higher if needed.
LLM_TIMEOUT_MS=

# Optional homepage "Watch demo" CTA on the landing page. Pick one:
#   - NEXT_PUBLIC_DEMO_VIDEO_URL: direct URL to an .mp4/.webm file. Opens
#     an inline modal with a <video> element. Takes precedence.
#   - NEXT_PUBLIC_DEMO_URL: external URL (YouTube, Loom, etc.). CTA is a
#     plain link-out when no video URL is set.
NEXT_PUBLIC_DEMO_URL=
NEXT_PUBLIC_DEMO_VIDEO_URL=
# Optional poster image shown before the video plays.
NEXT_PUBLIC_DEMO_VIDEO_POSTER=

# --- Instance branding (used by footer + legal pages) ---
# REQUIRED before deploying. The build fails loudly if any required value
# below is missing — this is deliberate, so self-hosters never silently
# ship the upstream project's contact email or governing-law clause on
# their own instance. Inlined at build time (not runtime — see README for
# Docker / Fly build-arg wiring).
#
# Required values (instance name, support email, governing law) are left
# blank on purpose so `cp .env.example .env.local && pnpm build` fails
# loudly instead of silently inheriting the upstream project's branding
# and contact details. NEXT_PUBLIC_SOURCE_URL is the one exception — the
# upstream URL is the correct AGPL §13 default for an unmodified
# deployment, so it ships pre-filled. Fill the rest in before deploying.

# Name shown in the header / footer / legal pages.
# Example: NEXT_PUBLIC_INSTANCE_NAME=Acme Signups
NEXT_PUBLIC_INSTANCE_NAME=

# Contact email shown in the footer and on the privacy policy.
# Example: NEXT_PUBLIC_SUPPORT_EMAIL=hello@acme.example
NEXT_PUBLIC_SUPPORT_EMAIL=

# Source-code URL. AGPL-3.0 §13 requires a network-deployed copy to make
# its corresponding source available. Must be https. If you haven't
# modified the code, leaving this pointed at upstream is a reasonable
# default; if you have, point at your fork.
NEXT_PUBLIC_SOURCE_URL=https://github.com/richshaw/OpenSignup

# Governing law clause used in the terms of service. Set this to your own
# jurisdiction.
# Example: NEXT_PUBLIC_GOVERNING_LAW=England and Wales
NEXT_PUBLIC_GOVERNING_LAW=

# Optional: name of the person or organisation operating this instance.
# Shown in the privacy policy ("data controller") and terms. Leave blank
# to use the generic fallback "the operator of this instance".
NEXT_PUBLIC_OPERATOR_NAME=
